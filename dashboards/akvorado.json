{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    },
    {
      "name": "DS_WAZUH_INDEXER",
      "label": "Wazuh Indexer",
      "type": "datasource",
      "pluginId": "elasticsearch"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "elasticsearch",
      "name": "Elasticsearch",
      "version": "1.0.0"
    }
  ],
  "panels": [
    {
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "DOWN"
                },
                "1": {
                  "color": "green",
                  "text": "UP"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "up{job=~\"akvorado_.*\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "title": "Component Status",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "unit": "h"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "akvorado_cmd_uptime_seconds / 3600",
          "legendFormat": "{{job}}"
        }
      ],
      "title": "Component Uptime",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "pps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "targets": [
        {
          "expr": "rate(akvorado_inlet_flow_input_udp_packets_total[5m])",
          "legendFormat": "packets/s"
        }
      ],
      "title": "Flow Packets/sec (Inlet)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "rate(akvorado_inlet_flow_input_udp_bytes_total[5m])",
          "legendFormat": "bytes/s"
        }
      ],
      "title": "Flow Data Rate (Inlet)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "targets": [
        {
          "expr": "rate(akvorado_inlet_flow_input_udp_errors_total[5m])",
          "legendFormat": "errors/s"
        },
        {
          "expr": "akvorado_inlet_flow_input_udp_in_dropped_packets_total",
          "legendFormat": "dropped (total)"
        }
      ],
      "title": "Flow Input Errors",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 6,
      "targets": [
        {
          "expr": "rate(akvorado_inlet_kafka_sent_messages_total[5m])",
          "legendFormat": "inlet sent msgs/s"
        },
        {
          "expr": "rate(akvorado_outlet_kafka_received_messages_total[5m])",
          "legendFormat": "outlet received msgs/s"
        },
        {
          "expr": "akvorado_outlet_kafka_consumergroup_lag_messages",
          "legendFormat": "consumer lag"
        }
      ],
      "title": "Kafka Pipeline",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "id": 7,
      "targets": [
        {
          "expr": "rate(akvorado_outlet_core_received_flows_total[5m])",
          "legendFormat": "received/s"
        },
        {
          "expr": "rate(akvorado_outlet_core_forwarded_flows_total[5m])",
          "legendFormat": "forwarded/s"
        }
      ],
      "title": "Flows Processed (Outlet)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "id": 8,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(akvorado_outlet_clickhouse_insert_time_seconds_bucket[5m]))",
          "legendFormat": "p95 insert time"
        }
      ],
      "title": "ClickHouse Insert Latency (p95)",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "id": 9,
      "targets": [
        {
          "expr": "rate(akvorado_outlet_metadata_provider_requests_total[5m])",
          "legendFormat": "requests/s"
        },
        {
          "expr": "rate(akvorado_outlet_metadata_provider_errors_total[5m])",
          "legendFormat": "errors/s"
        },
        {
          "expr": "akvorado_outlet_metadata_cache_size_entries",
          "legendFormat": "cache entries"
        }
      ],
      "title": "SNMP Metadata Polling",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "id": 10,
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=~\"akvorado_.*\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "title": "Component Memory Usage",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 40
      },
      "id": 11,
      "targets": [
        {
          "expr": "rate(akvorado_common_httpserver_requests_total{job=~\"akvorado_.*\"}[5m])",
          "legendFormat": "{{job}} {{handler}}"
        }
      ],
      "title": "HTTP Request Rate",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 40
      },
      "id": 12,
      "targets": [
        {
          "expr": "rate(akvorado_inlet_kafka_sent_bytes_total[5m])",
          "legendFormat": "inlet sent"
        },
        {
          "expr": "rate(akvorado_outlet_kafka_received_bytes_total[5m])",
          "legendFormat": "outlet received"
        }
      ],
      "title": "Kafka Throughput",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "akvorado",
    "netflow",
    "network"
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Akvorado Flow Pipeline",
  "uid": "akvorado"
}