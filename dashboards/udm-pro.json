{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    },
    {
      "name": "DS_WAZUH_INDEXER",
      "label": "Wazuh Indexer",
      "type": "datasource",
      "pluginId": "elasticsearch"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "elasticsearch",
      "name": "Elasticsearch",
      "version": "1.0.0"
    }
  ],
  "panels": [
    {
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "DOWN"
                },
                "1": {
                  "color": "green",
                  "text": "UP"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "up{job=\"snmp_udm_pro\"}",
          "legendFormat": "SNMP"
        }
      ],
      "title": "SNMP Status",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "FAIL"
                },
                "1": {
                  "color": "green",
                  "text": "OK"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "probe_success{instance=\"https://192.168.10.1\"}",
          "legendFormat": "HTTPS"
        }
      ],
      "title": "HTTPS Probe",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "unit": "d"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sysUpTime{job=\"snmp_udm_pro\"} / 100 / 86400",
          "legendFormat": "days"
        }
      ],
      "title": "Uptime",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "count(ifOperStatus{job=\"snmp_udm_pro\"} == 1)",
          "legendFormat": "UP"
        },
        {
          "expr": "count(ifOperStatus{job=\"snmp_udm_pro\"})",
          "legendFormat": "Total"
        }
      ],
      "title": "Interface Status",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "targets": [
        {
          "expr": "rate(ifHCInOctets{job=\"snmp_udm_pro\",ifDescr=\"eth0\"}[5m]) * 8",
          "legendFormat": "eth0 RX"
        },
        {
          "expr": "rate(ifHCOutOctets{job=\"snmp_udm_pro\",ifDescr=\"eth0\"}[5m]) * 8",
          "legendFormat": "eth0 TX"
        }
      ],
      "title": "WAN Traffic (eth0)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 6,
      "targets": [
        {
          "expr": "rate(ifHCInOctets{job=\"snmp_udm_pro\",ifDescr=\"eth1\"}[5m]) * 8",
          "legendFormat": "eth1 RX"
        },
        {
          "expr": "rate(ifHCOutOctets{job=\"snmp_udm_pro\",ifDescr=\"eth1\"}[5m]) * 8",
          "legendFormat": "eth1 TX"
        }
      ],
      "title": "WAN2 Traffic (eth1)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 7,
      "targets": [
        {
          "expr": "rate(ifHCInOctets{job=\"snmp_udm_pro\",ifDescr=~\"eth[2-7]\"}[5m]) * 8",
          "legendFormat": "{{ifDescr}} RX"
        },
        {
          "expr": "rate(ifHCOutOctets{job=\"snmp_udm_pro\",ifDescr=~\"eth[2-7]\"}[5m]) * 8",
          "legendFormat": "{{ifDescr}} TX"
        }
      ],
      "title": "LAN Ports (eth2-eth7)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 8,
      "targets": [
        {
          "expr": "rate(ifHCInOctets{job=\"snmp_udm_pro\",ifDescr=~\"br.*\"}[5m]) * 8",
          "legendFormat": "{{ifDescr}} RX"
        },
        {
          "expr": "rate(ifHCOutOctets{job=\"snmp_udm_pro\",ifDescr=~\"br.*\"}[5m]) * 8",
          "legendFormat": "{{ifDescr}} TX"
        }
      ],
      "title": "Bridge / VLAN Traffic",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "id": 9,
      "targets": [
        {
          "expr": "rate(ifHCInOctets{job=\"snmp_udm_pro\",ifDescr=~\"switch0.*\"}[5m]) * 8",
          "legendFormat": "{{ifDescr}} RX"
        },
        {
          "expr": "rate(ifHCOutOctets{job=\"snmp_udm_pro\",ifDescr=~\"switch0.*\"}[5m]) * 8",
          "legendFormat": "{{ifDescr}} TX"
        }
      ],
      "title": "Switch VLANs (switch0.*)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "id": 10,
      "targets": [
        {
          "expr": "rate(ifHCInOctets{job=\"snmp_udm_pro\",ifDescr=\"wgsrv1\"}[5m]) * 8",
          "legendFormat": "WG RX"
        },
        {
          "expr": "rate(ifHCOutOctets{job=\"snmp_udm_pro\",ifDescr=\"wgsrv1\"}[5m]) * 8",
          "legendFormat": "WG TX"
        }
      ],
      "title": "WireGuard VPN (wgsrv1)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "id": 11,
      "targets": [
        {
          "expr": "rate(ifHCInOctets{job=\"snmp_udm_pro\",ifDescr=~\"eth10.*|Annapurna.*\"}[5m]) * 8",
          "legendFormat": "{{ifDescr}} RX"
        },
        {
          "expr": "rate(ifHCOutOctets{job=\"snmp_udm_pro\",ifDescr=~\"eth10.*|Annapurna.*\"}[5m]) * 8",
          "legendFormat": "{{ifDescr}} TX"
        }
      ],
      "title": "SFP+ Ports (eth8-eth9)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "1": {
                  "color": "green",
                  "text": "UP"
                },
                "2": {
                  "color": "red",
                  "text": "DOWN"
                },
                "7": {
                  "color": "orange",
                  "text": "LOWER DOWN"
                }
              },
              "type": "value"
            }
          ]
        }
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "id": 12,
      "targets": [
        {
          "expr": "ifOperStatus{job=\"snmp_udm_pro\"}",
          "format": "table",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "title": "All Interfaces \u2014 Operational Status",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "ifIndex": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "Value": "Status",
              "ifDescr": "Interface",
              "ifName": "Name"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "network",
    "snmp",
    "udm"
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "UDM Pro",
  "uid": "udm-pro"
}