{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    },
    {
      "name": "DS_WAZUH_INDEXER",
      "label": "Wazuh Indexer",
      "type": "datasource",
      "pluginId": "elasticsearch"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "elasticsearch",
      "name": "Elasticsearch",
      "version": "1.0.0"
    }
  ],
  "panels": [
    {
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "count(container_last_seen{name!=\"\"})",
          "legendFormat": "Running"
        }
      ],
      "title": "Running Containers",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "DOWN"
                },
                "1": {
                  "color": "green",
                  "text": "UP"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 18,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "probe_success{job=\"bb_api_health\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "title": "API Health",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 3,
      "targets": [
        {
          "expr": "container:cpu_usage_percent:rate5m",
          "legendFormat": "{{name}}"
        }
      ],
      "title": "Container CPU Usage",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "unit": "decmbytes"
        }
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 4,
      "targets": [
        {
          "expr": "container:memory_usage_mb",
          "legendFormat": "{{name}}"
        }
      ],
      "title": "Container Memory Usage (MB)",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "id": 5,
      "targets": [
        {
          "expr": "container:network_rx_bytes_rate:5m",
          "legendFormat": "{{name}} RX"
        }
      ],
      "title": "Container Network RX",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "id": 6,
      "targets": [
        {
          "expr": "container:network_tx_bytes_rate:5m",
          "legendFormat": "{{name}} TX"
        }
      ],
      "title": "Container Network TX",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 22
      },
      "id": 7,
      "targets": [
        {
          "expr": "probe_duration_seconds{job=\"bb_api_health\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "title": "API Response Time",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 22
      },
      "id": 8,
      "targets": [
        {
          "expr": "rate(container_fs_reads_bytes_total{name!=\"\"}[5m])",
          "legendFormat": "{{name}} read"
        },
        {
          "expr": "rate(container_fs_writes_bytes_total{name!=\"\"}[5m])",
          "legendFormat": "{{name}} write"
        }
      ],
      "title": "Container Disk I/O",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 30
      },
      "id": 9,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "topk(10, container:memory_usage_mb)",
          "legendFormat": "{{name}}"
        }
      ],
      "title": "Top Containers by Memory",
      "type": "bargauge"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 30
      },
      "id": 10,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "topk(10, container:cpu_usage_percent:rate5m)",
          "legendFormat": "{{name}}"
        }
      ],
      "title": "Top Containers by CPU",
      "type": "bargauge"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": [
    "docker",
    "containers",
    "api"
  ],
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Docker Containers & APIs",
  "uid": "docker-containers"
}