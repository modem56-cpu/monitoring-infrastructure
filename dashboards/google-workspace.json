  "panels": [
    {
      "id": 50,
      "title": "Report Date (API Data)",
      "type": "stat",
      "description": "Date of the Google Workspace Reports API data used. Google lags 2\u20138 days behind real-time. If this date is older than expected, the collector may not be running.",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "gworkspace_report_date_unixtime * 1000",
          "legendFormat": ""
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsLocal",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "id": 51,
      "title": "Data Lag (Days)",
      "type": "stat",
      "description": "Days between the Google Reports API data date and today. Normal range is 2\u20138 days due to Google's reporting delay. Red = API data is stale beyond expected lag.",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "gworkspace_report_lag_days",
          "legendFormat": "days"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 6
              },
              {
                "color": "red",
                "value": 8
              }
            ]
          }
        }
      }
    },
    {
      "id": 52,
      "title": "Last Collection",
      "type": "stat",
      "description": "Timestamp of the last successful collector run. Used to detect if the systemd timer or collector script has stopped.",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "gworkspace_collector_last_success_unixtime * 1000",
          "legendFormat": ""
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsLocal",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "fieldConfig": {
        "defaults": {
          "mappings": [
