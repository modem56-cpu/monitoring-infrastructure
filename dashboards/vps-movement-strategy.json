{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    },
    {
      "name": "DS_WAZUH_INDEXER",
      "label": "Wazuh Indexer",
      "type": "datasource",
      "pluginId": "elasticsearch"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "elasticsearch",
      "name": "Elasticsearch",
      "version": "1.0.0"
    }
  ],
  "panels": [
    {
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "DOWN"
                },
                "1": {
                  "color": "green",
                  "text": "UP"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "vps_ssh_up{target=\"31.170.165.94\"}",
          "legendFormat": "SSH Collector"
        }
      ],
      "title": "Status",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "unit": "d"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "vps_uptime_seconds{target=\"31.170.165.94\"} / 86400",
          "legendFormat": "days"
        }
      ],
      "title": "Uptime",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "decimals": 2
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "vps_load1{target=\"31.170.165.94\"}",
          "legendFormat": "1m"
        }
      ],
      "title": "Load Average",
      "type": "stat"
    },
    {
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "orange",
                "value": 85
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "vps_rootfs_used_percent{target=\"31.170.165.94\"}",
          "legendFormat": "Root"
        }
      ],
      "title": "Disk Usage",
      "type": "gauge"
    },
    {
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "targets": [
        {
          "expr": "vps_cpu_busy_percent{target=\"31.170.165.94\"}",
          "legendFormat": "CPU %"
        }
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 6,
      "targets": [
        {
          "expr": "((vps_mem_total_bytes{target=\"31.170.165.94\"} - vps_mem_avail_bytes{target=\"31.170.165.94\"}) / vps_mem_total_bytes{target=\"31.170.165.94\"}) * 100",
          "legendFormat": "Memory %"
        },
        {
          "expr": "vps_swap_used_percent{target=\"31.170.165.94\"}",
          "legendFormat": "Swap %"
        }
      ],
      "title": "Memory Usage",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 7,
      "targets": [
        {
          "expr": "vps_net_rx_bytes_per_sec{target=\"31.170.165.94\"}",
          "legendFormat": "RX"
        },
        {
          "expr": "vps_net_tx_bytes_per_sec{target=\"31.170.165.94\"}",
          "legendFormat": "TX"
        }
      ],
      "title": "Network I/O",
      "type": "timeseries"
    },
    {
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 8,
      "targets": [
        {
          "expr": "vps_disk_read_bytes_per_sec{target=\"31.170.165.94\"}",
          "legendFormat": "Read"
        },
        {
          "expr": "vps_disk_write_bytes_per_sec{target=\"31.170.165.94\"}",
          "legendFormat": "Write"
        }
      ],
      "title": "Disk I/O",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "id": 9,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "vps_docker_running{target=\"31.170.165.94\"}",
          "legendFormat": "Running"
        },
        {
          "expr": "vps_docker_total{target=\"31.170.165.94\"}",
          "legendFormat": "Total"
        }
      ],
      "title": "Docker Containers",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "id": 10,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "vps_ssh_sessions{target=\"31.170.165.94\"}",
          "legendFormat": "Active"
        }
      ],
      "title": "SSH Sessions",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "vps",
    "movement-strategy"
  ],
  "time": {
    "from": "now-1h",
