{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    },
    {
      "name": "DS_WAZUH_INDEXER",
      "label": "Wazuh Indexer",
      "type": "datasource",
      "pluginId": "elasticsearch"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "elasticsearch",
      "name": "Elasticsearch",
      "version": "1.0.0"
    }
  ],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "UNHEALTHY"
                },
                "1": {
                  "color": "green",
                  "text": "HEALTHY"
                }
              },
              "type": "value"
            }
          ]
        }
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "vmbackup_backup_healthy",
          "instant": true,
          "legendFormat": "{{vm}}",
          "range": false
        }
      ],
      "title": "Backup Health",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "MISSING"
                },
                "1": {
                  "color": "green",
                  "text": "DEFINED"
                }
              },
              "type": "value"
            }
          ]
        }
      },
      "gridPos": {
        "h": 3,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "vmbackup_vm_defined",
          "instant": true,
          "legendFormat": "{{vm}}",
          "range": false
        }
      ],
      "title": "VM Defined in Libvirt",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "NO BACKUP"
                },
                "1": {
                  "color": "green",
                  "text": "EXISTS"
                }
              },
              "type": "value"
            }
          ]
        }
      },
      "gridPos": {
        "h": 3,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "vmbackup_has_backup",
          "instant": true,
          "legendFormat": "{{vm}}",
          "range": false
        }
      ],
      "title": "Has Backup Directory",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 432000
              },
              {
                "color": "orange",
                "value": 604800
              },
              {
                "color": "red",
                "value": 691200
              }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "id": 4,
      "options": {
        "displayMode": "lcd",
        "minVizHeight": 10,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "vmbackup_latest_age_seconds > 0",
          "instant": true,
          "legendFormat": "{{vm}}",
          "range": false
        }
      ],
      "title": "Backup Age (days)",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 52428800
              },
              {
                "color": "green",
                "value": 1073741824
              }
            ]
          },
          "unit": "bytes"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "id": 5,
      "options": {
        "displayMode": "lcd",
        "minVizHeight": 10,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "vmbackup_latest_disk_size_bytes > 0",
          "instant": true,
          "legendFormat": "{{vm}}",
          "range": false
        }
      ],
      "title": "Backup Disk Size",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20
          },
          "unit": "bytes"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "id": 6,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "vmbackup_latest_disk_size_bytes",
          "legendFormat": "{{vm}}"
        }
      ],
      "title": "Backup Size Over Time",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Issues"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "id": 7,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "vmbackup_total_vms",
          "instant": true,
          "legendFormat": "Defined VMs",
          "range": false
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "vmbackup_total_backed_up",
          "instant": true,
          "legendFormat": "With Backups",
          "range": false
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "vmbackup_total_healthy",
          "instant": true,
          "legendFormat": "Healthy",
          "range": false
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "vmbackup_total_vms - vmbackup_total_healthy",
          "instant": true,
          "legendFormat": "Issues",
          "range": false
        }
      ],
      "title": "Summary",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "id": 8,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "vmbackup_latest_xml_exists",
          "format": "table",
          "instant": true,
          "legendFormat": "{{vm}}",
          "range": false,
          "refId": "xml"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "vmbackup_latest_nvram_exists",
          "format": "table",
          "instant": true,
          "legendFormat": "{{vm}}",
          "range": false,
          "refId": "nvram"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "vmbackup_file_count",
          "format": "table",
          "instant": true,
          "legendFormat": "{{vm}}",
          "range": false,
          "refId": "files"
        }
      ],
      "title": "Backup Components",
      "type": "table"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": [
    "backup",
    "unraid",
    "vm"
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "VM Backups (Unraid)",
  "uid": "vm-backups"
}