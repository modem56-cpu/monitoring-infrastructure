  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "True Orphaned Accounts",
      "description": "GW accounts with no employee record, not a service account, not an authorized admin",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "afiwke54zcjcwe"
          },
          "expr": "employee_reconcile_true_orphaned_accounts or vector(0)",
          "instant": true,
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 2,
