            "properties": [
              {
                "id": "custom.width",
                "value": 80
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "true": {
                        "color": "red",
                        "index": 0,
                        "text": "ADMIN"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "false": {
                        "color": "green",
                        "index": 1,
                        "text": "user"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Time"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
