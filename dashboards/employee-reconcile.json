      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true
            },
            "renameByName": {
              "email": "Email",
              "name": "Name",
              "is_admin": "Admin?",
              "authorized": "Authorized"
            }
          }
        }
      ]
