#!/usr/bin/env python3
import os, sys, json, time, math, html
from urllib.parse import urlencode
from urllib.request import urlopen

PROM = os.environ.get("PROM_URL", "http://127.0.0.1:9090").rstrip("/")

def prom_query(q: str):
    url = f"{PROM}/api/v1/query?{urlencode({'query': q})}"
    with urlopen(url, timeout=15) as r:
        data = json.loads(r.read().decode("utf-8"))
    if data.get("status") != "success":
        return []
    return data.get("data", {}).get("result", []) or []

def q_scalar(expr: str):
    res = prom_query(expr)
    vals = []
    for it in res:
        v = it.get("value", [None, None])[1]
        try:
            fv = float(v)
            # keep NaN as NaN for callers that care
            vals.append(fv)
        except Exception:
            pass
    if not vals:
        return None
    # prefer max to collapse duplicate jobs for same instance
    # but if all are NaN, return NaN
    non_nan = [x for x in vals if not (isinstance(x, float) and math.isnan(x))]
    if non_nan:
        return max(non_nan)
    return float("nan")

def q_first(*exprs):
    for e in exprs:
        v = q_scalar(e)
        if v is not None:
            return v
    return None

def q_vector(expr: str):
    return prom_query(expr)

def pick_label(expr: str, key: str):
    res = prom_query(expr)
    for it in res:
        m = it.get("metric", {})
        if key in m:
            return m[key]
    return None

def fmt_bytes(b):
    if b is None:
        return "N/A"
    try:
        b = float(b)
    except Exception:
        return "N/A"
    units = ["B","KiB","MiB","GiB","TiB","PiB"]
    i = 0
    while b >= 1024 and i < len(units)-1:
        b /= 1024.0
        i += 1
    return f"{b:.2f} {units[i]}"

def fmt_rate(bps):
    if bps is None:
        return "N/A"
    return f"{fmt_bytes(bps)}/s"

def fmt_pct(x):
    if x is None:
        return "N/A"
    return f"{x:.2f} %"

def fmt_age(seconds):
    if seconds is None:
        return "N/A"
    try:
        s = float(seconds)
        if math.isnan(s):
            return "never"
    except Exception:
        return "N/A"
    if s < 0:
        s = 0
    if s < 60:
        return f"{int(s)}s"
    if s < 3600:
        return f"{s/60:.1f}m"
    if s < 86400:
        return f"{s/3600:.2f}h"
    return f"{s/86400:.2f}d"

def esc(s):
    return html.escape("" if s is None else str(s), quote=True)

def main():
    if len(sys.argv) < 2:
        print("Usage: prom_tower_dashboard_html.sh <instance:port>")
        sys.exit(2)
    inst = sys.argv[1].strip()
    now = time.time()

    # meta
    up = q_scalar(f'max by (instance) (up{{instance="{inst}"}})')
    job = pick_label(f'up{{instance="{inst}"}}', "job")
    alias = pick_label(f'up{{instance="{inst}"}}', "alias")
    nodename = pick_label(f'node_uname_info{{instance="{inst}"}}', "nodename") or pick_label(f'node_uname_info{{instance="{inst}"}}', "nodename")
    kernel = pick_label(f'node_uname_info{{instance="{inst}"}}', "release")

    # cpu busy %
    cpu_busy = q_scalar(
        f'100 - (avg by (instance) (rate(node_cpu_seconds_total{{instance="{inst}",mode="idle"}}[2m])) * 100)'
    )

    # memory
    mem_total = q_scalar(f'max by (instance) (node_memory_MemTotal_bytes{{instance="{inst}"}})')
    mem_avail = q_scalar(f'max by (instance) (node_memory_MemAvailable_bytes{{instance="{inst}"}})')
    mem_used = None if (mem_total is None or mem_avail is None) else max(mem_total - mem_avail, 0)
    mem_pct = None if (mem_total is None or mem_total == 0 or mem_used is None) else (mem_used / mem_total * 100)

    # swap
    swap_total = q_scalar(f'max by (instance) (node_memory_SwapTotal_bytes{{instance="{inst}"}})')
    swap_free  = q_scalar(f'max by (instance) (node_memory_SwapFree_bytes{{instance="{inst}"}})')
    swap_used = None if (swap_total is None or swap_free is None) else max(swap_total - swap_free, 0)
    swap_pct = None if (swap_total is None or swap_total == 0 or swap_used is None) else (swap_used / swap_total * 100)

    # docker counts (standard + unraid fallback)
    docker_running = q_first(
        f'tower_docker_running{{instance="{inst}"}}',
        f'tower_extras_docker_containers_running{{instance="{inst}"}}'
    )
    docker_total = q_first(
        f'tower_docker_total{{instance="{inst}"}}',
        f'tower_extras_docker_containers_total{{instance="{inst}"}}'
    )

    # ssh sessions (standard or sum per-session if available)
    ssh_sessions = q_first(
        f'tower_ssh_sessions{{instance="{inst}"}}',
        f'sum(tower_ssh_session{{instance="{inst}"}})'
    )

    # smb sessions (unraid extras)
    smb_sessions = q_first(
        f'tower_smb_sessions{{instance="{inst}"}}',
        f'tower_extras_smb_sessions{{instance="{inst}"}}'
    )

    # wireguard peers
    wg_rows = []
    wg_counts = {"active":0, "idle":0, "stale":0, "never":0}
    wg_vec = q_vector(f'wireguard_peer_handshake_age_seconds{{instance="{inst}"}}')
    if wg_vec:
        for it in wg_vec:
            m = it.get("metric", {})
            v = it.get("value", [None, None])[1]
            try:
                fv = float(v)
            except Exception:
                continue
            iface = m.get("iface","")
            peer = m.get("peer","")
            if isinstance(fv, float) and math.isnan(fv):
                status = "never"
                age_disp = "never"
            else:
                age = max(fv, 0.0)
                age_disp = fmt_age(age)
                if age <= 120:
                    status = "active"
                elif age <= 3600:
                    status = "idle"
                else:
                    status = "stale"
            wg_counts[status] += 1
            wg_rows.append((iface, peer, age_disp, status))
        wg_rows.sort(key=lambda r: (r[0], r[3], r[2]))
    # smb shares/users (unraid extras)
    smb_shares = []
    for it in q_vector(f'tower_extras_smb_share_security{{instance="{inst}"}}'):
        m = it.get("metric", {})
        share = m.get("share")
        sec = m.get("security")
        if share and sec:
            smb_shares.append((share, sec))
    smb_shares.sort(key=lambda x: x[0].lower())

    smb_users = []
    for it in q_vector(f'tower_extras_smb_user_configured{{instance="{inst}"}}'):
        u = it.get("metric", {}).get("user")
        if u:
            smb_users.append(u)
    smb_users = sorted(set(smb_users), key=lambda x: x.lower())

    # ssh last login/seen (standard + unraid extras)
    ssh_last = []
    ts_vec = q_vector(f'tower_ssh_last_seen_timestamp_seconds{{instance="{inst}"}}')
    if not ts_vec:
        ts_vec = q_vector(f'tower_extras_ssh_last_login_timestamp_seconds{{instance="{inst}"}}')
    for it in ts_vec:
        m = it.get("metric", {})
        u = m.get("user","")
        src = m.get("src","")
        v = it.get("value",[None,None])[1]
        try:
            ts = float(v)
        except Exception:
            continue
        age_h = (now - ts)/3600.0 if ts else None
        ssh_last.append((u, src, age_h, ts))
    ssh_last.sort(key=lambda r: (r[0], r[1]))

    # top processes by RSS
    rss_vec = q_vector(f'topk(100, sys_topproc_rss_kb{{instance="{inst}"}})')
    cpu_vec = q_vector(f'sys_topproc_pcpu_percent{{instance="{inst}"}}')
    mem_vec = q_vector(f'sys_topproc_pmem_percent{{instance="{inst}"}}')
    vsz_vec = q_vector(f'sys_topproc_vsz_kb{{instance="{inst}"}}')

    def key_of(it):
        m = it.get("metric", {})
        return (m.get("rank",""), m.get("user",""), m.get("pid",""), m.get("comm",""), m.get("exe",""))

    cpu_map = {}
    for it in cpu_vec:
        try:
            cpu_map[key_of(it)] = float(it["value"][1])
        except Exception:
            pass

    mem_map = {}
    for it in mem_vec:
        try:
            mem_map[key_of(it)] = float(it["value"][1])
        except Exception:
            pass

    vsz_map = {}
    for it in vsz_vec:
        try:
            vsz_map[key_of(it)] = float(it["value"][1])
        except Exception:
            pass

    rows = []
    for it in rss_vec:
        m = it.get("metric", {})
        k = key_of(it)
        try:
            rss = float(it["value"][1])
        except Exception:
            continue
        rank = int(m.get("rank","0") or "0")
        user = m.get("user","")
        pid  = m.get("pid","")
        comm = m.get("comm","")
        exe  = m.get("exe","")
        cpu = cpu_map.get(k)
        mem = mem_map.get(k)
        vsz = vsz_map.get(k)
        rows.append((rank, user, pid, cpu, mem, vsz, rss, comm, exe))
    rows.sort(key=lambda r: r[0])

    title = f"Tower Dashboard (Prometheus) — {inst}"
    out = f"/opt/monitoring/reports/tower_{inst.replace('.','_').replace(':','_')}.html"

    def card(label, value, sub=None):
        return f'''
        <div class="card">
          <div class="label">{esc(label)}</div>
          <div class="value">{esc(value)}</div>
          {f'<div class="sub">{esc(sub)}</div>' if sub else ''}
        </div>'''

    docker_line = "Docker: N/A" if docker_running is None or docker_total is None else f"Docker: {int(docker_running)} running / {int(docker_total)} total"
    ssh_line = "SSH sessions: N/A" if ssh_sessions is None else f"SSH sessions: {int(ssh_sessions)}"
    smb_line = "SMB sessions: N/A" if smb_sessions is None else f"SMB sessions: {int(smb_sessions)}"
    wg_line = ""
    if wg_vec:
        wg_line = f"WireGuard: active {wg_counts['active']} idle {wg_counts['idle']} stale {wg_counts['stale']} never {wg_counts['never']}"

    textfile_err = q_scalar(f'max by (instance) (node_textfile_scrape_error{{instance="{inst}"}})')

    html_doc = f"""<!doctype html>
<html>
<head>
<meta charset="utf-8"/>
<title>{esc(title)}</title>
<style>
  body {{ font-family: Arial, sans-serif; margin: 18px; color:#111; }}
  h1 {{ font-size: 22px; margin: 0 0 6px 0; }}
  .meta {{ color:#444; font-size: 12px; margin-bottom: 14px; }}
  .grid {{ display: grid; grid-template-columns: repeat(4, minmax(220px, 1fr)); gap: 12px; }}
  .card {{ border:1px solid #ddd; border-radius:10px; padding: 12px 14px; background:#fff; }}
  .label {{ font-size: 12px; color:#444; margin-bottom: 6px; }}
  .value {{ font-size: 18px; font-weight: 700; }}
  .sub {{ font-size: 12px; color:#444; margin-top: 6px; }}
  table {{ border-collapse: collapse; width: 100%; margin-top: 10px; }}
  th, td {{ border:1px solid #ddd; padding: 8px; font-size: 12px; text-align:left; vertical-align: top; }}
  th {{ background:#f3f3f3; }}
  .section {{ margin-top: 18px; }}
</style>
</head>
<body>
  <h1>{esc(title)}</h1>
  <div class="meta">
    Generated: {time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())} |
    Prometheus: {esc(PROM)} |
    {f'Alias: {esc(alias)} | ' if alias else ''}{f'Host: {esc(nodename)} | ' if nodename else ''}{f'Kernel: {esc(kernel)} | ' if kernel else ''}{f'Job: {esc(job)} | ' if job else ''}up={esc(int(up)) if up is not None else 'N/A'}
  </div>

  <div class="grid">
    {card("CPU Utilization", f"{fmt_pct(cpu_busy)} busy")}
    {card("Memory Usage", f"{fmt_bytes(mem_used)} of {fmt_bytes(mem_total)} ({fmt_pct(mem_pct)})", f"Avail {fmt_bytes(mem_avail)}")}
    {card("Swap Usage", f"{fmt_bytes(swap_used)} of {fmt_bytes(swap_total)} ({fmt_pct(swap_pct)})")}
    {card("Tower Extras (textfile metrics)", docker_line, ssh_line)}
  </div>

  <div class="meta">node_textfile_scrape_error: {esc(textfile_err if textfile_err is not None else 'N/A')}</div>

  <div class="section">
    <h2 style="font-size:16px;margin:0 0 8px 0;">Extras</h2>
    <div class="meta">{esc(wg_line) if wg_line else ""}</div>
    <div class="meta">{esc(smb_line)}</div>
  </div>

  {"<div class='section'><h2 style='font-size:16px;margin:0 0 8px 0;'>WireGuard peers</h2><table><tr><th>IFACE</th><th>PEER</th><th>AGE</th><th>STATUS</th></tr>" + "".join([f"<tr><td>{esc(r[0])}</td><td>{esc(r[1])}</td><td>{esc(r[2])}</td><td>{esc(r[3])}</td></tr>" for r in wg_rows]) + "</table></div>" if wg_rows else ""}

  {"<div class='section'><h2 style='font-size:16px;margin:0 0 8px 0;'>SMB shares</h2><table><tr><th>SHARE</th><th>SECURITY</th></tr>" + "".join([f"<tr><td>{esc(s)}</td><td>{esc(sec)}</td></tr>" for s,sec in smb_shares]) + "</table></div>" if smb_shares else ""}

  {"<div class='section'><h2 style='font-size:16px;margin:0 0 8px 0;'>SMB users (configured)</h2><div class='meta'>" + esc(", ".join(smb_users)) + "</div></div>" if smb_users else ""}

  {"<div class='section'><h2 style='font-size:16px;margin:0 0 8px 0;'>SSH last logins</h2><table><tr><th>USER</th><th>SRC</th><th>AGE (hours)</th><th>LAST SEEN (UTC)</th></tr>" + "".join([f"<tr><td>{esc(u)}</td><td>{esc(src)}</td><td>{esc(f'{age_h:.2f}' if age_h is not None else 'N/A')}</td><td>{esc(time.strftime('%Y-%m-%d %H:%M:%S', time.gmtime(ts)))}</td></tr>" for u,src,age_h,ts in ssh_last]) + "</table></div>" if ssh_last else ""}

  <div class="section">
    <h2 style="font-size:16px;margin:0 0 8px 0;">Top Processes by RSS (Top 100)</h2>
    <div class="meta">PromQL: topk(100, sys_topproc_rss_kb{{instance="{esc(inst)}"}})</div>
    <table>
      <tr><th>#</th><th>USER</th><th>PID</th><th>%CPU</th><th>%MEM</th><th>VSZ (KB)</th><th>RSS (KB)</th><th>COMM</th><th>EXE_PATH</th></tr>
      {''.join([f"<tr><td>{r[0]}</td><td>{esc(r[1])}</td><td>{esc(r[2])}</td><td>{esc('N/A' if r[3] is None else f'{r[3]:.2f}')}</td><td>{esc('N/A' if r[4] is None else f'{r[4]:.2f}')}</td><td>{esc('N/A' if r[5] is None else f'{int(r[5])}')}</td><td>{esc(int(r[6]))}</td><td>{esc(r[7])}</td><td>{esc(r[8])}</td></tr>" for r in rows])}
    </table>
  </div>
</body>
</html>
"""
    with open(out, "w", encoding="utf-8") as f:
        f.write(html_doc)
    print("Saved:", out)

if __name__ == "__main__":
    main()
